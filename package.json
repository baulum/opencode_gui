{
  "name": "opencode-gui",
  "displayName": "OpenCode GUI",
  "description": "AI coding chat powered by OpenCode",
  "version": "0.1.0",
  "publisher": "opencode",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Programming Languages", "Other"],
  "activationEvents": [
    "onCommand:opencode-gui.start",
    "onView:opencode-gui.chat"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        { "id": "opencode-gui", "title": "OpenCode", "icon": "$(terminal)" }
      ]
    },
    "views": {
      "opencode-gui": [
        { "type": "webview", "id": "opencode-gui.chat", "name": "Chat" }
      ]
    },
    "commands": [
      { "command": "opencode-gui.start", "title": "OpenCode: Open Chat" },
      { "command": "opencode-gui.newSession", "title": "OpenCode: New Session" },
      { "command": "opencode-gui.selectModel", "title": "OpenCode: Select Model" },
      { "command": "opencode-gui.editSystemPrompt", "title": "OpenCode: Edit System Prompt" }
    ],
    "keybindings": [
      { "key": "ctrl+shift+i", "command": "opencode-gui.start" }
    ],
    "configuration": {
      "title": "OpenCode GUI",
      "properties": {
        "opencode-gui.cliPath": {
          "type": "string",
          "default": "opencode",
          "description": "Path to the opencode CLI binary"
        },
        "opencode-gui.zenApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenCode Zen API key for cloud models"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.config.js && cd webview && npm run build",
    "dev": "node esbuild.config.js --watch",
    "lint": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
